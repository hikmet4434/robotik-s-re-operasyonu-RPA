{
  "manifest_version": 3,
  "name": "OtoFlow Recorder",
  "version": "0.4.0",
  "description": "KOBİ işleri için tıklama, input, sekme ve sayfa olaylarını OtoFlow Recorder Studio'ya aktarır.",
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["http://localhost:4100/*", "http://localhost:5173/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OtoFlow Recorder"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
