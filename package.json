{
  "name": "otoflow-ai-rpa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:all": "concurrently -k \"npm:dev:server\" \"npm:dev:client\" \"npm:dev:agent\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "dev:agent": "npm --prefix agents/local-agent start",
    "setup:agent": "npm --prefix agents/local-agent install",
    "build": "tsc --noEmit && vite build && node scripts/build-sites-worker.mjs",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "preview": "vite preview --host 0.0.0.0",
    "start": "tsx src/server/index.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "tsx": "^4.20.6",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "rc9": "^3.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.3.6"
  }
}
