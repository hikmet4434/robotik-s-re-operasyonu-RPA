PORT=4100
DATABASE_PATH=./data/otoflow.sqlite
SAAS_DATABASE_PATH=./data/otoflow-saas.sqlite
CREDENTIAL_VAULT_KEY=change-this-32-byte-production-secret
OTOFLOW_AGENT_TOKEN=change-this-local-agent-shared-token

# Sunucu tarafinda OpenRouter uc-model fallback zinciri.
OPENROUTER_API_KEY=sk-or-v1-change-me
OPENROUTER_MODEL_PRIMARY=z-ai/glm-5.2
OPENROUTER_MODEL_FALLBACK_1=moonshotai/kimi-k3
OPENROUTER_MODEL_FALLBACK_2=deepseek/deepseek-v4-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Yerel ajan aynı değerleri kullanır.
OTOFLOW_API_BASE=http://localhost:4100
OTOFLOW_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
OTOFLOW_UI_ORIGINS=http://localhost:5173,https://rpa.example.com
CORS_ORIGINS=https://rpa.example.com

# Canlı deploy hedefi için Prisma/PostgreSQL bağlantısı.
DATABASE_URL="postgresql://otoflow:otoflow@localhost:5432/otoflow_ai?schema=public"
